{
  "name": "helpdesk",
  "private": true,
  "workspaces": ["client", "server"],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:client": "bun run --filter client dev",
    "dev:server": "bun run --filter server dev",
    "test": "bun run --filter client test",
    "test:watch": "bun run --filter client test:watch",
    "test:e2e": "bun e2e/setup-db.ts && bunx playwright test",
    "test:e2e:ui": "bun e2e/setup-db.ts && bunx playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/pg": "^8.20.0",
    "pg": "^8.20.0"
  }
}
