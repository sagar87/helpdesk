generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  AGENT
}

enum TicketStatus {
  OPEN
  RESOLVED
  CLOSED
}

enum TicketCategory {
  GENERAL_QUESTION
  TECHNICAL_QUESTION
  REFUND_REQUEST
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(AGENT)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedTickets Ticket[]  @relation("AssignedAgent")
  sessions        Session[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Ticket {
  id          String         @id @default(uuid())
  subject     String
  body        String
  senderEmail String
  senderName  String
  status      TicketStatus   @default(OPEN)
  category    TicketCategory?
  aiSummary   String?
  assignedTo  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  agent    User?    @relation("AssignedAgent", fields: [assignedTo], references: [id])
  messages Message[]
}

model Message {
  id        String   @id @default(uuid())
  ticketId  String
  body      String
  sender    String
  isAi      Boolean  @default(false)
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}
